{
  "name": "bolt-expo-starter",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "node ./scripts/patch-node18-compat.cjs",
    "start": "node -r ./scripts/node18-polyfills.cjs ./node_modules/expo/bin/cli start",
    "dev": "node -r ./scripts/node18-polyfills.cjs ./node_modules/expo/bin/cli start",
    "build:web": "node -r ./scripts/node18-polyfills.cjs ./node_modules/expo/bin/cli export --platform web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "android": "node -r ./scripts/node18-polyfills.cjs ./node_modules/expo/bin/cli run:android",
    "ios": "node -r ./scripts/node18-polyfills.cjs ./node_modules/expo/bin/cli run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@lucide/lab": "^0.1.2",
    "cors": "^2.8.6",
    "expo": "^56.0.9",
    "expo-blur": "~56.0.3",
    "expo-camera": "~56.0.7",
    "expo-constants": "~56.0.17",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image-picker": "~56.0.16",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.9",
    "expo-sharing": "~56.0.16",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^0.544.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.2.14",
    "typescript": "~6.0.3"
  }
}
